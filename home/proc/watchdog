#!/bin/sh

. /usr/bin/jupiter-common

NETWORK_CONFIG="/etc/jupiter/network.json"
WATCHDOG_LOG_FILE="/var/log/watchdog.log"
PWR_KEY="/dev/pwr_key"
PPP_IFACE="${PPP_IFACE:-ppp0}"
DEVICE_WAIT_SECONDS="${JUPITER_LTE_DEVICE_WAIT_SECONDS:-60}"

isUP=false

json_object_bool() {
    file="$1"
    object="$2"
    key="$3"
    [ -f "$file" ] || return 0
    tr '\n' ' ' < "$file" \
        | sed -n 's/.*"'"$object"'"[[:space:]]*:[[:space:]]*{[^}]*"'"$key"'"[[:space:]]*:[[:space:]]*\(true\|false\).*/\1/p' \
        | head -n 1
}

json_object_string() {
    file="$1"
    object="$2"
    key="$3"
    [ -f "$file" ] || return 0
    tr '\n' ' ' < "$file" \
        | sed -n 's/.*"'"$object"'"[[:space:]]*:[[:space:]]*{[^}]*"'"$key"'"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' \
        | head -n 1
}

json_object_number() {
    file="$1"
    object="$2"
    key="$3"
    [ -f "$file" ] || return 0
    tr '\n' ' ' < "$file" \
        | sed -n 's/.*"'"$object"'"[[:space:]]*:[[:space:]]*{[^}]*"'"$key"'"[[:space:]]*:[[:space:]]*\([0-9][0-9]*\).*/\1/p' \
        | head -n 1
}

json_object_first_array_string() {
    file="$1"
    object="$2"
    key="$3"
    [ -f "$file" ] || return 0
    tr '\n' ' ' < "$file" \
        | sed -n 's/.*"'"$object"'"[[:space:]]*:[[:space:]]*{[^}]*"'"$key"'"[[:space:]]*:[[:space:]]*\[[[:space:]]*"\([^"]*\)".*/\1/p' \
        | head -n 1
}

log(){
    jupiter_log watchdog "$1"
    echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" >> "$WATCHDOG_LOG_FILE"
}

ppp_iface_up() {
    ifconfig "$PPP_IFACE" > /dev/null 2>&1
}

ppp_ipv4_address() {
    ifconfig "$PPP_IFACE" 2>/dev/null \
        | sed -n 's/.*inet addr:\([0-9.][0-9.]*\).*/\1/p; s/.*inet \([0-9.][0-9.]*\).*/\1/p' \
        | head -n 1
}

ppp_has_ipv4() {
    [ -n "$(ppp_ipv4_address)" ]
}

ppp_health_ok() {
    ppp_has_ipv4 || return 1
    ping "$HEALTH_TARGET" -c 1 -W 5 -I "$PPP_IFACE" > /dev/null 2>&1
}

stop_pppd() {
    ifconfig "$PPP_IFACE" down 2>/dev/null

    if pidof pppd >/dev/null 2>&1; then
        log "Encerrando processo pppd anterior..."
        killall pppd 2>/dev/null
        sleep 2
    fi
}

wait_for_modem_device() {
    elapsed=0

    while [ "$elapsed" -lt "$DEVICE_WAIT_SECONDS" ]; do
        [ -e "$USB_PPP" ] && return 0
        sleep 1
        elapsed=$((elapsed + 1))
    done

    return 1
}

wait_for_ppp_health() {
    elapsed=0

    while [ "$elapsed" -lt "$STARTUP_WAIT" ]; do
        ppp_health_ok && return 0
        sleep 1
        elapsed=$((elapsed + 1))
    done

    return 1
}

load_config() {
    LTE_ENABLED="$(json_object_bool "$NETWORK_CONFIG" lte enabled)"
    PEERS="$(json_object_string "$NETWORK_CONFIG" lte peer)"
    CHAT_FILE="$(json_object_string "$NETWORK_CONFIG" lte chat_file)"
    USB_PPP="$(json_object_string "$NETWORK_CONFIG" lte device)"
    HEALTH_TARGET="$(json_object_first_array_string "$NETWORK_CONFIG" lte health_targets)"
    CHECK_INTERVAL="$(json_object_number "$NETWORK_CONFIG" lte check_interval_seconds)"
    STARTUP_WAIT="$(json_object_number "$NETWORK_CONFIG" lte startup_wait_seconds)"

    case "$CHECK_INTERVAL" in
        ""|*[!0-9]*) CHECK_INTERVAL=60 ;;
    esac

    case "$STARTUP_WAIT" in
        ""|*[!0-9]*) STARTUP_WAIT=30 ;;
    esac
}

validate_config() {
    if [ "$LTE_ENABLED" != "true" ]; then
        log "LTE disabled"
        exit 0
    fi

    if [ -z "$PEERS" ] || [ ! -f "/etc/ppp/peers/$PEERS" ]; then
        log "LTE peer not configured"
        exit 0
    fi

    if [ -n "$CHAT_FILE" ] && [ ! -f "$CHAT_FILE" ]; then
        log "LTE chat file not found: $CHAT_FILE"
        exit 0
    fi

    if [ -z "$USB_PPP" ]; then
        log "LTE modem device not configured"
        exit 0
    fi

    if [ -z "$HEALTH_TARGET" ]; then
        log "LTE health target not configured"
        exit 0
    fi
}

watchdog(){

    if [ "$isUP" = "false" ]; then
        if ppp_health_ok; then
            isUP=true
            log "Conexao LTE ja esta ativa."
            return
        fi

        if ! wait_for_modem_device; then
            log "Device LTE nao encontrado apos ${DEVICE_WAIT_SECONDS}s: $USB_PPP"
            reset_modem
            return
        fi

        stop_pppd
        log "Iniciando conexao LTE peer=$PEERS device=$USB_PPP chat=$CHAT_FILE target=$HEALTH_TARGET"
        pppd call "$PEERS" nodetach debug >> "$WATCHDOG_LOG_FILE" 2>&1 &

        if wait_for_ppp_health; then
            isUP=true
            log "Conexao LTE estabelecida com sucesso. ip=$(ppp_ipv4_address)"
            return
        fi

        isUP=false
        if ! ppp_iface_up; then
            log "Interface $PPP_IFACE nao subiu apos ${STARTUP_WAIT}s."
        elif ! ppp_has_ipv4; then
            log "Interface $PPP_IFACE subiu, mas nao recebeu IPv4 apos ${STARTUP_WAIT}s."
        else
            log "Interface $PPP_IFACE recebeu IPv4 $(ppp_ipv4_address), mas ping para $HEALTH_TARGET falhou."
        fi
        stop_pppd
        reset_modem
        return
    else
        if ppp_health_ok; then
            return
        fi

        isUP=false
        log "Conexao LTE perdida ou sem resposta em $HEALTH_TARGET."
        stop_pppd
        reset_modem
        return
    fi
}

reset_modem(){
    log "Resetando modem..."
    power_off_modem
    sleep 5
    power_on_modem
}

power_on_modem(){
    log "Ligando modem..."
    if [ ! -e "$PWR_KEY" ]; then
        log "Power key device not found: $PWR_KEY"
        return
    fi
    echo 1 > "$PWR_KEY"
    sleep 1
    echo 0 > "$PWR_KEY"
}

power_off_modem(){
    log "Desligando modem..."
    if [ ! -e "$PWR_KEY" ]; then
        log "Power key device not found: $PWR_KEY"
        return
    fi
    echo 1 > "$PWR_KEY"
    sleep 5
    echo 0 > "$PWR_KEY"
}

load_config
validate_config

while true; do
    watchdog
    sleep "$CHECK_INTERVAL"
done
