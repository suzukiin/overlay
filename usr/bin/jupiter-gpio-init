#!/bin/sh

. /usr/bin/jupiter-common

export_gpio() {
    local gpio="$1"
    local direction="$2"
    local link_path="$3"

    if [ ! -d "/sys/class/gpio/gpio$gpio" ]; then
        echo "$gpio" > /sys/class/gpio/export
    fi

    echo "$direction" > "/sys/class/gpio/gpio$gpio/direction"
    ln -sf "/sys/class/gpio/gpio$gpio/value" "$link_path"
}

configure_vin_bias() {
    local chip="${JUPITER_VIN_GPIOCHIP:-gpiochip0}"
    local line="${JUPITER_VIN_GPIO_LINE:-6}"
    local value

    if command -v gpioget >/dev/null 2>&1; then
        value="$(gpioget -B disable "$chip" "$line" 2>/dev/null)" || {
            jupiter_log gpio "failed to disable vin bias chip=$chip line=$line"
            return 1
        }

        case "$value" in
            0|1)
                rm -f /dev/vin_status
                echo "$value" > /dev/vin_status
                chmod 0644 /dev/vin_status
                jupiter_log gpio "vin bias disabled chip=$chip line=$line value=$value"
                return 0
                ;;
            *)
                jupiter_log gpio "invalid vin value from gpioget chip=$chip line=$line value=$value"
                return 1
                ;;
        esac
    else
        jupiter_log gpio "gpioget not available; vin bias not changed"
        return 1
    fi
}

read_legacy_relay_state() {
    if [ -f /var/lib/jupiter/state/relay_state ]; then
        read relay1_state relay2_state < /var/lib/jupiter/state/relay_state
    elif [ -f /etc/jupiter/relay_state ]; then
        read relay1_state relay2_state < /etc/jupiter/relay_state
    else
        relay1_state=0
        relay2_state=0
    fi

    case "$relay1_state" in
        0|1) ;;
        *) relay1_state=0 ;;
    esac

    case "$relay2_state" in
        0|1) ;;
        *) relay2_state=0 ;;
    esac
}

persist_legacy_relay_state() {
    echo "$relay1_state $relay2_state" > /var/lib/jupiter/state/relay_state
    echo "$relay1_state $relay2_state" > /etc/jupiter/relay_state
}

jupiter_mkdirs

export_gpio 591 out /dev/relay1
export_gpio 592 out /dev/relay2
export_gpio 586 out /dev/pwr_key
configure_vin_bias || export_gpio 575 in /dev/vin_status

read_legacy_relay_state
persist_legacy_relay_state

echo "$relay1_state" > /dev/relay1
echo "$relay2_state" > /dev/relay2
echo 0 > /dev/pwr_key

jupiter_log gpio "initialized relays=$relay1_state,$relay2_state"
