#!/bin/sh

. /usr/bin/jupiter-common

usage() {
    echo "Usage: $0 DEVICE_ID MQTT_PASSWORD [TENANT] [SITE_ID]"
    exit 1
}

shell_quote() {
    printf "%s" "$1" | sed "s/'/'\\\\''/g"
}

validate_key() {
    local name="$1"
    local value="$2"

    case "$value" in
        ""|*[!A-Za-z0-9._-]*)
            echo "Invalid $name. Use only letters, numbers, dot, underscore and dash."
            exit 1
            ;;
    esac
}

device_id="$1"
mqtt_password="$2"
tenant="${3:-lab-service}"
site_id="${4:-unknown-site}"
quoted_password="$(shell_quote "$mqtt_password")"

[ -n "$device_id" ] || usage
[ -n "$mqtt_password" ] || usage

validate_key DEVICE_ID "$device_id"
validate_key TENANT "$tenant"
validate_key SITE_ID "$site_id"

jupiter_mkdirs

tmp_device="/tmp/jupiter-device.json"
tmp_fleet="/tmp/jupiter-fleet.json"

cat > "$tmp_device" <<EOF
{
  "schema_version": 1,
  "device_id": "$device_id",
  "serial_number": "$device_id",
  "model": "jupiter-telemetry",
  "hardware_revision": "rev-a",
  "firmware_version": "0.0.1",
  "provisioning": {
    "mode": "factory",
    "status": "provisioned"
  }
}
EOF

cat > "$tmp_fleet" <<EOF
{
  "schema_version": 1,
  "tenant": "$tenant",
  "environment": "production",
  "site": {
    "id": "$site_id",
    "name": "$site_id",
    "country": "BR"
  },
  "mqtt_topics": {
    "base": "jupiter",
    "pattern": "jupiter/{tenant}/{site_id}/{device_id}/{channel}"
  },
  "update_channel": "stable"
}
EOF

mv "$tmp_device" /etc/jupiter/device.json
mv "$tmp_fleet" /etc/jupiter/fleet.json

{
    echo "# Generated by jupiter-provision."
    echo "JUPITER_MQTT_PASSWORD='$quoted_password'"
} > /etc/jupiter/secrets.env

chmod 600 /etc/jupiter/secrets.env
jupiter_log provision "provisioned device_id=$device_id tenant=$tenant site=$site_id"
