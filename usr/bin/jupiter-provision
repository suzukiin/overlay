#!/bin/sh

. /usr/bin/jupiter-common

usage() {
    echo "Usage: $0 DEVICE_ID MQTT_PASSWORD [TENANT] [SITE_ID] [SITE_NAME] [MQTT_HOST] [MQTT_PORT]"
    exit 1
}

shell_quote() {
    printf "%s" "$1" | sed "s/'/'\\\\''/g"
}

json_escape() {
    printf "%s" "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

validate_key() {
    local name="$1"
    local value="$2"

    case "$value" in
        ""|*[!A-Za-z0-9._-]*)
            echo "Invalid $name. Use only letters, numbers, dot, underscore and dash."
            exit 1
            ;;
    esac
}

device_id="$1"
mqtt_password="$2"
tenant="${3:-lab-service}"
site_id="${4:-unknown-site}"
site_name="${5:-$site_id}"
mqtt_host="${6:-129.121.45.199}"
mqtt_port="${7:-1883}"
quoted_password="$(shell_quote "$mqtt_password")"

[ -n "$device_id" ] || usage
[ -n "$mqtt_password" ] || usage

validate_key DEVICE_ID "$device_id"
validate_key TENANT "$tenant"
validate_key SITE_ID "$site_id"

case "$mqtt_host" in
    ""|*[!A-Za-z0-9._:-]*)
        echo "Invalid MQTT_HOST."
        exit 1
        ;;
esac

case "$mqtt_port" in
    ""|*[!0-9]*)
        echo "Invalid MQTT_PORT."
        exit 1
        ;;
esac

jupiter_mkdirs
mkdir -p /home/proc

tmp_device="/tmp/jupiter-device.json"
tmp_fleet="/tmp/jupiter-fleet.json"
tmp_legacy="/tmp/jupiter-legacy-device.json"
tmp_info="/tmp/jupiter-info.json"
tmp_mqtt="/tmp/jupiter-mqtt.json"

cat > "$tmp_device" <<EOF
{
  "schema_version": 1,
  "device_id": "$(json_escape "$device_id")",
  "serial_number": "$(json_escape "$device_id")",
  "model": "jupiter-telemetry",
  "hardware_revision": "rev-a",
  "firmware_version": "0.0.1",
  "provisioning": {
    "mode": "factory",
    "status": "provisioned"
  }
}
EOF

cat > "$tmp_fleet" <<EOF
{
  "schema_version": 1,
  "tenant": "$(json_escape "$tenant")",
  "environment": "production",
  "site": {
    "id": "$(json_escape "$site_id")",
    "name": "$(json_escape "$site_name")",
    "country": "BR"
  },
  "mqtt_topics": {
    "base": "jupiter",
    "pattern": "jupiter/{device_id}/{channel}"
  },
  "update_channel": "stable"
}
EOF

cat > "$tmp_legacy" <<EOF
{
  "device_id": "$(json_escape "$device_id")"
}
EOF

cat > "$tmp_info" <<EOF
{
  "location": "$(json_escape "$site_name")",
  "client": "$(json_escape "$tenant")",
  "deviceId": "$(json_escape "$device_id")",
  "wanIp": "",
  "lanIp": "",
  "version": "0.0.1",
  "siteId": "$(json_escape "$site_id")",
  "siteName": "$(json_escape "$site_name")"
}
EOF

cat > "$tmp_mqtt" <<EOF
{
  "host": "$(json_escape "$mqtt_host")",
  "port": $mqtt_port,
  "device_id": "$(json_escape "$device_id")",
  "username": "$(json_escape "$device_id")",
  "password": "",
  "client_id": "$(json_escape "$device_id")",
  "fw_version": "0.0.1",
  "snmp_community": "public",
  "polling_interval": 10,
  "identity_file": "/home/proc/jupiter.json",
  "info_file": "/home/proc/info.json",
  "inputs_file": "/home/proc/virtual_inputs.json",
  "output_file": "/home/proc/telemetry_data.json",
  "vin_status_path": "/dev/vin_status",
  "relay_paths": [
    "/dev/relay1",
    "/dev/relay2"
  ],
  "analog_inputs": [
    { "name": "analog_1", "path": "/var/lib/jupiter/iio/ads1015/in_voltage0_raw", "scale": 1.0, "offset": 0.0, "unit": "raw" },
    { "name": "analog_2", "path": "/var/lib/jupiter/iio/ads1015/in_voltage1_raw", "scale": 1.0, "offset": 0.0, "unit": "raw" },
    { "name": "analog_3", "path": "/var/lib/jupiter/iio/ads1015/in_voltage2_raw", "scale": 1.0, "offset": 0.0, "unit": "raw" },
    { "name": "analog_4", "path": "/var/lib/jupiter/iio/ads1015/in_voltage3_raw", "scale": 1.0, "offset": 0.0, "unit": "raw" }
  ]
}
EOF

mv "$tmp_device" /home/proc/device.json
mv "$tmp_fleet" /etc/jupiter/fleet.json
mv "$tmp_legacy" /home/proc/jupiter.json
mv "$tmp_info" /home/proc/info.json
mv "$tmp_mqtt" /home/proc/mqtt.json

{
    echo "# Generated by jupiter-provision."
    echo "JUPITER_MQTT_PASSWORD='$quoted_password'"
} > /home/proc/secrets.env

chmod 600 /home/proc/secrets.env
jupiter_log provision "provisioned device_id=$device_id tenant=$tenant site=$site_id mqtt=$mqtt_host:$mqtt_port"
