#!/bin/sh

. /usr/bin/jupiter-common

usage() {
    echo "Usage: $0 DEVICE_ID MQTT_PASSWORD MQTT_HOST [MQTT_PORT] [TENANT] [SITE_ID] [SITE_NAME]"
    exit 1
}

shell_quote() {
    printf "%s" "$1" | sed "s/'/'\\\\''/g"
}

json_escape() {
    printf "%s" "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

validate_key() {
    local name="$1"
    local value="$2"

    case "$value" in
        ""|*[!A-Za-z0-9._-]*)
            echo "Invalid $name. Use only letters, numbers, dot, underscore and dash."
            exit 1
            ;;
    esac
}

device_id="$1"
mqtt_password="$2"
mqtt_host="$3"
mqtt_port="${4:-1883}"
tenant="${5:-unassigned}"
site_id="${6:-unknown-site}"
site_name="${7:-$site_id}"
quoted_password="$(shell_quote "$mqtt_password")"

[ -n "$device_id" ] || usage
[ -n "$mqtt_password" ] || usage
[ -n "$mqtt_host" ] || usage

validate_key DEVICE_ID "$device_id"
validate_key TENANT "$tenant"
validate_key SITE_ID "$site_id"

case "$mqtt_host" in
    ""|*[!A-Za-z0-9._:-]*)
        echo "Invalid MQTT_HOST."
        exit 1
        ;;
esac

case "$mqtt_port" in
    ""|*[!0-9]*)
        echo "Invalid MQTT_PORT."
        exit 1
        ;;
esac

jupiter_mkdirs
mkdir -p /etc/jupiter /home/proc

tmp_device="/tmp/jupiter-device.json"
tmp_fleet="/tmp/jupiter-fleet.json"
tmp_info="/tmp/jupiter-info.json"
tmp_mqtt="/tmp/jupiter-mqtt.json"

cat > "$tmp_device" <<EOF
{
  "schema_version": 1,
  "device_id": "$(json_escape "$device_id")",
  "serial_number": "$(json_escape "$device_id")",
  "model": "jupiter-telemetry",
  "hardware_revision": "rev-a",
  "firmware_version": "0.0.1",
  "provisioning": {
    "mode": "factory",
    "status": "provisioned"
  }
}
EOF

cat > "$tmp_fleet" <<EOF
{
  "schema_version": 1,
  "tenant": "$(json_escape "$tenant")",
  "environment": "production",
  "site": {
    "id": "$(json_escape "$site_id")",
    "name": "$(json_escape "$site_name")",
    "country": "BR"
  },
  "mqtt_topics": {
    "base": "jupiter",
    "pattern": "jupiter/{device_id}/{channel}"
  },
  "update_channel": "stable"
}
EOF

cat > "$tmp_info" <<EOF
{
  "location": "$(json_escape "$site_name")",
  "client": "$(json_escape "$tenant")",
  "deviceId": "$(json_escape "$device_id")",
  "wanIp": "",
  "lanIp": "",
  "version": "0.0.1",
  "siteId": "$(json_escape "$site_id")",
  "siteName": "$(json_escape "$site_name")"
}
EOF

cat > "$tmp_mqtt" <<EOF
{
  "host": "$(json_escape "$mqtt_host")",
  "port": $mqtt_port
}
EOF

mv "$tmp_device" /etc/jupiter/device.json
mv "$tmp_fleet" /etc/jupiter/fleet.json
mv "$tmp_info" /home/proc/info.json
mv "$tmp_mqtt" /home/proc/mqtt.json

{
    echo "# Generated by jupiter-provision."
    echo "JUPITER_MQTT_PASSWORD='$quoted_password'"
} > /home/proc/secrets.env

chmod 600 /home/proc/secrets.env
jupiter_log provision "provisioned device_id=$device_id tenant=$tenant site=$site_id mqtt=$mqtt_host:$mqtt_port"
