#!/bin/sh

. /usr/bin/jupiter-common

SCHEDULER_PID="$JUPITER_RUN/relay-scheduler.pid"
WEB_PID="$JUPITER_RUN/web.pid"
VIN_MONITOR_PID="$JUPITER_RUN/vin-monitor.pid"
MONITOR_PID="$JUPITER_RUN/monitor.pid"

start_pid_service() {
    local name="$1"
    local pid_file="$2"
    shift 2

    jupiter_mkdirs

    if [ -f "$pid_file" ] && kill -0 "$(cat "$pid_file")" 2>/dev/null; then
        jupiter_log "$name" "already running"
        return 0
    fi

    "$@" &
    echo "$!" > "$pid_file"
    jupiter_log "$name" "started pid=$(cat "$pid_file")"
}

stop_pid_service() {
    local name="$1"
    local pid_file="$2"

    if [ -f "$pid_file" ] && kill -0 "$(cat "$pid_file")" 2>/dev/null; then
        kill "$(cat "$pid_file")"
        rm -f "$pid_file"
        jupiter_log "$name" "stopped"
        return 0
    fi

    rm -f "$pid_file"
    jupiter_log "$name" "not running"
}

start_scheduler() {
    start_pid_service relay-scheduler "$SCHEDULER_PID" /usr/bin/jupiter-relay-scheduler
}

start_web() {
    start_pid_service web "$WEB_PID" /usr/bin/jupiter-web
}

start_monitor() {
    start_pid_service monitor "$MONITOR_PID" /usr/bin/jupiter-monitor /etc/jupiter/mqtt.json
}

start_vin_monitor() {
    /usr/bin/jupiter-led-init || jupiter_log led "initialization failed; continuing without leds"
    if [ -e /dev/jupiter_leds ] && { [ -e /dev/vin_status ] || command -v gpioget >/dev/null 2>&1; }; then
        start_pid_service vin-monitor "$VIN_MONITOR_PID" /usr/bin/jupiter-vin-monitor
    else
        jupiter_log vin-monitor "not started; missing led or vin device"
    fi
}

stop_scheduler() {
    stop_pid_service relay-scheduler "$SCHEDULER_PID"
}

stop_web() {
    stop_pid_service web "$WEB_PID"
}

stop_vin_monitor() {
    stop_pid_service vin-monitor "$VIN_MONITOR_PID"
}

start_services() {
    jupiter_mkdirs

    /usr/bin/jupiter-config-check >/dev/null 2>&1 || jupiter_log services "configuration check failed; starting services with current files"

    if [ -f /etc/jupiter/secrets.env ]; then
        . /etc/jupiter/secrets.env
        export JUPITER_MQTT_PASSWORD
    fi

    start_web
    jupiter_start_once watchdog /usr/bin/jupiter-watchdog
    start_monitor
    start_scheduler
    start_vin_monitor
}

stop_services() {
    stop_vin_monitor
    stop_web
    stop_pid_service monitor "$MONITOR_PID"
    jupiter_stop watchdog
    stop_scheduler
}

case "$1" in
    start)
        start_services
        ;;
    stop)
        stop_services
        ;;
    restart)
        stop_services
        start_services
        ;;
    *)
        echo "Usage: $0 {start|stop|restart}"
        exit 1
        ;;
esac
