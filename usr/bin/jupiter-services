#!/bin/sh

. /usr/bin/jupiter-common

SCHEDULER_PID="$JUPITER_RUN/relay-scheduler.pid"

start_pid_service() {
    local name="$1"
    local pid_file="$2"
    shift 2

    jupiter_mkdirs

    if [ -f "$pid_file" ] && kill -0 "$(cat "$pid_file")" 2>/dev/null; then
        jupiter_log "$name" "already running"
        return 0
    fi

    "$@" &
    echo "$!" > "$pid_file"
    jupiter_log "$name" "started pid=$(cat "$pid_file")"
}

stop_pid_service() {
    local name="$1"
    local pid_file="$2"

    if [ -f "$pid_file" ] && kill -0 "$(cat "$pid_file")" 2>/dev/null; then
        kill "$(cat "$pid_file")"
        rm -f "$pid_file"
        jupiter_log "$name" "stopped"
        return 0
    fi

    rm -f "$pid_file"
    jupiter_log "$name" "not running"
}

start_scheduler() {
    start_pid_service relay-scheduler "$SCHEDULER_PID" /usr/bin/jupiter-relay-scheduler
}

stop_scheduler() {
    stop_pid_service relay-scheduler "$SCHEDULER_PID"
}

start_services() {
    jupiter_mkdirs

    if [ -f /etc/jupiter/secrets.env ]; then
        . /etc/jupiter/secrets.env
        export JUPITER_MQTT_PASSWORD
    fi

    jupiter_start_once httpd httpd -p 80 -h /www/jupiter
    jupiter_start_once watchdog /usr/bin/jupiter-watchdog
    jupiter_start_once monitor /usr/bin/jupiter-monitor /etc/jupiter/mqtt.json
    start_scheduler
}

stop_services() {
    jupiter_stop httpd
    jupiter_stop monitor
    jupiter_stop watchdog
    stop_scheduler
}

case "$1" in
    start)
        start_services
        ;;
    stop)
        stop_services
        ;;
    restart)
        stop_services
        start_services
        ;;
    *)
        echo "Usage: $0 {start|stop|restart}"
        exit 1
        ;;
esac
