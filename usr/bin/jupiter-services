#!/bin/sh

. /usr/bin/jupiter-common

SCHEDULER_PID="$JUPITER_RUN/relay-scheduler.pid"
WEB_PID="$JUPITER_RUN/web.pid"
VIN_MONITOR_PID="$JUPITER_RUN/vin-monitor.pid"
MONITOR_PID="$JUPITER_RUN/monitor.pid"
STATUS_LEDS_PID="$JUPITER_RUN/status-leds.pid"

start_pid_service() {
    local name="$1"
    local pid_file="$2"
    shift 2

    jupiter_mkdirs

    if [ -f "$pid_file" ] && kill -0 "$(cat "$pid_file")" 2>/dev/null; then
        jupiter_log "$name" "already running"
        return 0
    fi

    "$@" &
    echo "$!" > "$pid_file"
    jupiter_log "$name" "started pid=$(cat "$pid_file")"
}

stop_pid_service() {
    local name="$1"
    local pid_file="$2"

    if [ -f "$pid_file" ] && kill -0 "$(cat "$pid_file")" 2>/dev/null; then
        kill "$(cat "$pid_file")"
        rm -f "$pid_file"
        jupiter_log "$name" "stopped"
        return 0
    fi

    rm -f "$pid_file"
    jupiter_log "$name" "not running"
}

start_scheduler() {
    start_pid_service relay-scheduler "$SCHEDULER_PID" /usr/bin/jupiter-relay-scheduler
}

start_web() {
    start_pid_service web "$WEB_PID" /usr/bin/jupiter-web
}

start_monitor() {
    if ! /usr/bin/jupiter-config-check monitor-ready >/dev/null 2>&1; then
        rm -f "$MONITOR_PID"
        jupiter_log monitor "not started; device is not provisioned"
        return 0
    fi

    start_pid_service monitor "$MONITOR_PID" /usr/bin/jupiter-monitor /home/proc/mqtt.json
}

start_vin_monitor() {
    /usr/bin/jupiter-led-init || jupiter_log led "initialization failed; continuing without leds"
    if [ -e /dev/jupiter_leds ] && { [ -e /dev/vin_status ] || command -v gpioget >/dev/null 2>&1; }; then
        start_pid_service vin-monitor "$VIN_MONITOR_PID" /usr/bin/jupiter-vin-monitor
    else
        jupiter_log vin-monitor "not started; missing led or vin device"
    fi
}

start_status_leds() {
    if [ -e /dev/jupiter_leds ]; then
        start_pid_service status-leds "$STATUS_LEDS_PID" /usr/bin/jupiter-status-leds
    else
        jupiter_log status-leds "not started; missing led device"
    fi
}

start_watchdog() {
    if /usr/bin/jupiter-config-check lte-ready >/dev/null 2>&1; then
        jupiter_start_once watchdog /usr/bin/jupiter-watchdog
    else
        pidof watchdog >/dev/null 2>&1 && jupiter_stop watchdog
        jupiter_log watchdog "not started; LTE is not provisioned"
    fi
}

stop_scheduler() {
    stop_pid_service relay-scheduler "$SCHEDULER_PID"
}

stop_web() {
    stop_pid_service web "$WEB_PID"
}

stop_vin_monitor() {
    stop_pid_service vin-monitor "$VIN_MONITOR_PID"
}

stop_status_leds() {
    stop_pid_service status-leds "$STATUS_LEDS_PID"
}

stop_watchdog() {
    jupiter_stop watchdog
}

start_services() {
    jupiter_mkdirs

    /usr/bin/jupiter-config-check >/dev/null 2>&1 || jupiter_log services "configuration check failed; starting services with current files"

    if [ -f /home/proc/secrets.env ]; then
        . /home/proc/secrets.env
        export JUPITER_MQTT_PASSWORD
    fi

    start_web
    start_watchdog
    start_monitor
    start_scheduler
    start_vin_monitor
    start_status_leds
}

stop_services() {
    stop_status_leds
    stop_vin_monitor
    stop_web
    stop_pid_service monitor "$MONITOR_PID"
    stop_watchdog
    stop_scheduler
}

case "$1" in
    start)
        start_services
        ;;
    stop)
        stop_services
        ;;
    restart)
        stop_services
        start_services
        ;;
    *)
        echo "Usage: $0 {start|stop|restart}"
        exit 1
        ;;
esac
