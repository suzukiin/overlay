#!/bin/sh

COMMON="${JUPITER_COMMON:-/usr/bin/jupiter-common}"
if [ ! -f "$COMMON" ]; then
    COMMON="$(dirname "$0")/jupiter-common"
fi

. "$COMMON"

CONFIG_FILE="${JUPITER_MQTT_CONFIG:-/etc/jupiter/mqtt.json}"
MONITOR_PID="${JUPITER_MONITOR_PID:-/var/run/jupiter/monitor.pid}"
MONITOR_LOG="${JUPITER_MONITOR_LOG:-/var/log/jupiter/monitor.log}"
CHECK_INTERVAL="${JUPITER_STATUS_LED_INTERVAL:-5}"
RSSI_CGI="${JUPITER_RSSI_CGI:-/usr/libexec/jupiter/legacy-cgi/get-rssi}"
VIN_STATUS_FILE="${JUPITER_VIN_STATUS_FILE:-/dev/vin_status}"
VIN_PRESENT_VALUE="${JUPITER_VIN_PRESENT_VALUE:-0}"
VPN_INTERFACE="${JUPITER_VPN_INTERFACE:-wg0}"
VPN_HANDSHAKE_MAX_AGE="${JUPITER_VPN_HANDSHAKE_MAX_AGE:-180}"
VPN_PROBE_HOST="${JUPITER_VPN_PROBE_HOST:-10.100.1.1}"

json_get_string() {
    file="$1"
    key="$2"
    [ -f "$file" ] || return 0
    sed -n 's/.*"'"$key"'"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' "$file" | head -n 1
}

json_get_number() {
    file="$1"
    key="$2"
    [ -f "$file" ] || return 0
    sed -n 's/.*"'"$key"'"[[:space:]]*:[[:space:]]*\([-0-9.][0-9.]*\).*/\1/p' "$file" | head -n 1
}

host_reachable() {
    local host="$1"
    local port="$2"

    [ -n "$host" ] || return 1
    [ -n "$port" ] || port=1883

    if command -v nc >/dev/null 2>&1; then
        nc -z -w 3 "$host" "$port" >/dev/null 2>&1 && return 0
    fi

    if command -v ping >/dev/null 2>&1; then
        ping -c 1 -W 2 "$host" >/dev/null 2>&1
        return $?
    fi

    return 0
}

internet_ok() {
    host_reachable 8.8.8.8 53
}

broker_ok() {
    local host
    local port

    host="$(json_get_string "$CONFIG_FILE" host)"
    port="$(json_get_number "$CONFIG_FILE" port)"
    [ -n "$port" ] || port=1883

    host_reachable "$host" "$port"
}

monitor_ok() {
    [ -f "$MONITOR_PID" ] && kill -0 "$(cat "$MONITOR_PID")" 2>/dev/null
}

vin_ok() {
    local value

    [ -f "$VIN_STATUS_FILE" ] || return 1
    value="$(cat "$VIN_STATUS_FILE" 2>/dev/null)"
    [ "$value" = "$VIN_PRESENT_VALUE" ]
}

mqtt_ok() {
    local last_state

    monitor_ok || return 1

    if [ -f "$MONITOR_LOG" ]; then
        last_state="$(tail -n 80 "$MONITOR_LOG" 2>/dev/null \
            | sed -n '/MQTT connected/s/.*/connected/p;/MQTT connect failed/s/.*/failed/p;/MQTT disconnected unexpectedly/s/.*/failed/p;/Unable to start MQTT connection/s/.*/failed/p' \
            | tail -n 1)"
        case "$last_state" in
            connected) return 0 ;;
            failed) return 1 ;;
        esac
    fi

    broker_ok
}

vpn_ok() {
    local latest
    local now

    if command -v wg >/dev/null 2>&1; then
        latest="$(wg show "$VPN_INTERFACE" latest-handshakes 2>/dev/null | awk '{print $2}' | sort -nr | head -n 1)"
        case "$latest" in
            ''|0) ;;
            *)
                now="$(date +%s)"
                [ $((now - latest)) -le "$VPN_HANDSHAKE_MAX_AGE" ] && return 0
                ;;
        esac
    fi

    if command -v ping >/dev/null 2>&1; then
        ping -I "$VPN_INTERFACE" -c 1 -W 2 "$VPN_PROBE_HOST" >/dev/null 2>&1 && return 0
    fi

    return 1
}

read_rssi() {
    local output

    [ -x "$RSSI_CGI" ] || return 1
    output="$("$RSSI_CGI" 2>/dev/null)"
    echo "$output" | sed -n 's/.*"rssi"[[:space:]]*:[[:space:]]*\([0-9][0-9]*\).*/\1/p' | head -n 1
}

rssi_colors() {
    local rssi="$1"

    case "$rssi" in
        ''|*[!0-9]*|99)
            echo "off off off"
            return
            ;;
    esac

    if [ "$rssi" -ge 20 ]; then
        echo "green green green"
    elif [ "$rssi" -ge 15 ]; then
        echo "green green off"
    elif [ "$rssi" -ge 10 ]; then
        echo "yellow off off"
    elif [ "$rssi" -gt 0 ]; then
        echo "red off off"
    else
        echo "off off off"
    fi
}

jupiter_mkdirs
jupiter_log status-leds "started interval=${CHECK_INTERVAL}s"
LAST_ERROR_SUMMARY=""

while true; do
    rssi="$(read_rssi)"
    set -- $(rssi_colors "$rssi")
    rssi1="$1"
    rssi2="$2"
    rssi3="$3"

    vpn_color="red"
    vpn_ok && vpn_color="green"

    error_color="green"
    error_summary=""
    internet_ok || error_summary="${error_summary} internet"
    mqtt_ok || error_summary="${error_summary} mqtt"
    vin_ok || error_summary="${error_summary} vin"
    if [ -n "$error_summary" ]; then
        error_color="red"
        if [ "$error_summary" != "$LAST_ERROR_SUMMARY" ]; then
            jupiter_log status-leds "status error:$error_summary"
            LAST_ERROR_SUMMARY="$error_summary"
        fi
    elif [ -n "$LAST_ERROR_SUMMARY" ]; then
        jupiter_log status-leds "status ok"
        LAST_ERROR_SUMMARY=""
    fi

    /usr/bin/jupiter-led status blue "$vpn_color" "$rssi1" "$rssi2" "$rssi3" "$error_color" || true
    sleep "$CHECK_INTERVAL"
done
