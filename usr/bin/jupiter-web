#!/bin/sh

COMMON="${JUPITER_COMMON:-/usr/bin/jupiter-common}"
if [ ! -f "$COMMON" ]; then
    COMMON="$(dirname "$0")/jupiter-common"
fi

. "$COMMON"

WEB_ROOT="${JUPITER_WEB_ROOT:-/www}"
WEB_PORT="${JUPITER_WEB_PORT:-80}"
HTTPD_BIN="${JUPITER_HTTPD_BIN:-}"

if [ ! -d "$WEB_ROOT" ] || [ ! -f "$WEB_ROOT/index.html" ]; then
    jupiter_log web "invalid web root: $WEB_ROOT"
    exit 1
fi

if [ -z "$HTTPD_BIN" ]; then
    HTTPD_BIN="$(command -v httpd 2>/dev/null)"
fi

if [ -n "$HTTPD_BIN" ]; then
    jupiter_log web "starting BusyBox httpd root=$WEB_ROOT port=$WEB_PORT"
    exec "$HTTPD_BIN" -f -p "$WEB_PORT" -h "$WEB_ROOT"
fi

if command -v busybox >/dev/null 2>&1; then
    jupiter_log web "starting BusyBox httpd root=$WEB_ROOT port=$WEB_PORT"
    exec busybox httpd -f -p "$WEB_PORT" -h "$WEB_ROOT"
fi

jupiter_log web "BusyBox httpd not found"
exit 1
