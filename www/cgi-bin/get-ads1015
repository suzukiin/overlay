#!/bin/sh

ADS_DIR="${JUPITER_ADS_DIR:-/var/lib/jupiter/iio/ads1015}"
DIVIDER_R1_OHM="68000"
DIVIDER_R2_OHM="33000"
DIVIDER_RATIO="$(awk -v r1="$DIVIDER_R1_OHM" -v r2="$DIVIDER_R2_OHM" 'BEGIN { printf "%.9f", (r1 + r2) / r2 }')"
BATTERY_CHANNEL="3"
BATTERY_MIN_V="3.50"
BATTERY_MAX_V="4.35"

json_response() {
    printf "Content-Type: application/json\r\n\r\n"
    printf "%s\n" "$1"
}

valid_number() {
    echo "$1" | grep -Eq '^-?[0-9]+([.][0-9]+)?$'
}

kernel_scale_file() {
    local channel="$1"

    if [ -f "$ADS_DIR/in_voltage${channel}_scale" ]; then
        echo "$ADS_DIR/in_voltage${channel}_scale"
    elif [ -f "$ADS_DIR/in_voltage_scale" ]; then
        echo "$ADS_DIR/in_voltage_scale"
    fi
}

read_channel() {
    local channel="$1"
    local raw_file="$ADS_DIR/in_voltage${channel}_raw"
    local scale_file
    local raw
    local kernel_scale="1"
    local ads_voltage
    local input_voltage
    local battery_percent

    [ -f "$raw_file" ] || return 1
    raw="$(cat "$raw_file" 2>/dev/null)" || return 1

    scale_file="$(kernel_scale_file "$channel")"
    if [ -n "$scale_file" ] && [ -f "$scale_file" ]; then
        kernel_scale="$(cat "$scale_file" 2>/dev/null)"
        valid_number "$kernel_scale" || kernel_scale="1"
    fi

    # O ABI IIO expressa tensão em milivolts depois de raw * scale.
    ads_voltage="$(awk -v raw="$raw" -v scale="$kernel_scale" 'BEGIN { printf "%.6f", (raw * scale) / 1000 }')"
    # Divisor fixo: Vin = Vadc * ((68k + 33k) / 33k).
    input_voltage="$(awk -v ads="$ads_voltage" -v ratio="$DIVIDER_RATIO" 'BEGIN { printf "%.6f", ads * ratio }')"

    if [ "$channel" = "$BATTERY_CHANNEL" ]; then
        battery_percent="$(awk -v voltage="$input_voltage" -v min="$BATTERY_MIN_V" -v max="$BATTERY_MAX_V" 'BEGIN {
            percent = ((voltage - min) / (max - min)) * 100
            if (percent < 0) percent = 0
            if (percent > 100) percent = 100
            printf "%.0f", percent
        }')"
        printf '{"channel":%s,"role":"battery","raw":%s,"kernel_scale":%s,"ads_voltage":%s,"divider_ratio":%s,"divider_r1_ohm":%s,"divider_r2_ohm":%s,"voltage":%s,"unit":"V","battery_percent":%s,"battery_min_voltage":%s,"battery_max_voltage":%s}' \
            "$channel" "$raw" "$kernel_scale" "$ads_voltage" "$DIVIDER_RATIO" "$DIVIDER_R1_OHM" "$DIVIDER_R2_OHM" "$input_voltage" \
            "$battery_percent" "$BATTERY_MIN_V" "$BATTERY_MAX_V"
    else
        printf '{"channel":%s,"role":"analog_input","raw":%s,"kernel_scale":%s,"ads_voltage":%s,"divider_ratio":%s,"divider_r1_ohm":%s,"divider_r2_ohm":%s,"voltage":%s,"unit":"V"}' \
            "$channel" "$raw" "$kernel_scale" "$ads_voltage" "$DIVIDER_RATIO" "$DIVIDER_R1_OHM" "$DIVIDER_R2_OHM" "$input_voltage"
    fi
}

handle_get() {
    local channels=""
    local channel_json
    local channel

    for channel in 0 1 2 3; do
        channel_json="$(read_channel "$channel")" || {
            json_response '{"status":"Error","msg":"ADS1015 not available"}'
            return 1
        }

        if [ -z "$channels" ]; then
            channels="$channel_json"
        else
            channels="$channels,$channel_json"
        fi
    done

    json_response "{\"status\":\"Success\",\"data\":{\"channels\":[$channels]}}"
}

case "$REQUEST_METHOD" in
    GET|"")
        handle_get
        ;;
    *)
        json_response '{"status":"Error","msg":"Method not allowed"}'
        ;;
esac
