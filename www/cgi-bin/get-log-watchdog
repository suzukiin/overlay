#!/bin/sh

WATCHDOG_LOG="${JUPITER_WATCHDOG_LOG:-/var/log/watchdog.log}"
SYSTEM_LOG="${JUPITER_SYSTEM_LOG:-/var/log/jupiter/system.log}"
limit=60

for item in $(printf '%s' "${QUERY_STRING:-}" | tr '&' ' '); do
    case "$item" in
        limit=*) limit="${item#limit=}" ;;
    esac
done

case "$limit" in
    ''|*[!0-9]*) limit=60 ;;
esac
[ "$limit" -lt 10 ] 2>/dev/null && limit=10
[ "$limit" -gt 200 ] 2>/dev/null && limit=200

if [ -r "$WATCHDOG_LOG" ]; then
    log_file="$WATCHDOG_LOG"
elif [ -r "$SYSTEM_LOG" ]; then
    log_file="$SYSTEM_LOG"
else
    printf 'Content-Type: application/json\r\n\r\n'
    printf '{"status":"Error","msg":"Nao foi possivel abrir o log"}\n'
    exit 0
fi

total="$(wc -l < "$log_file" | tr -d ' ')"
shown="$total"
[ "$shown" -gt "$limit" ] && shown="$limit"

printf 'Content-Type: application/json\r\n\r\n'
printf '{"status":"Success","total":%s,"shown":%s,"logs":[' "$total" "$shown"
tail -n "$limit" "$log_file" | awk '
BEGIN { first = 1 }
{
    gsub(/\\/, "\\\\", $0)
    gsub(/"/, "\\\"", $0)
    gsub(/\r/, "\\r", $0)
    gsub(/\t/, "\\t", $0)
    if (!first) printf ","
    printf "\"%s\"", $0
    first = 0
}'
printf ']}\n'
