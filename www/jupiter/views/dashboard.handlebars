<!DOCTYPE html>
<html lang="pt-BR" data-bs-theme="dark">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>JUPITER | Telemetry System</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&family=JetBrains+Mono:wght@400;700&display=swap"
        rel="stylesheet">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="public/style.css">
</head>

<body>
    <nav class="navbar navbar-expand-lg navbar-dark fixed-top">
        <div class="container-fluid">
            <a class="navbar-brand d-flex align-items-center col-md-3 col-lg-2 me-0 px-3 fs-6" href="#">
                <i class="bi bi-cpu-fill me-2 text-jupiter"></i>
                <span class="brand-text">JUPITER</span>
            </a>
            <div class="d-none d-md-flex w-100 justify-content-end px-3 align-items-center text-light navbar-status">
                <div class="me-3 text-end">
                    <div class="small text-muted">Localidade</div>
                    <div id="location-config-nav" class="text-light font-mono">--</div>
                </div>
                <div class="me-3 text-end">
                    <div class="small text-muted">Cliente</div>
                    <div id="client-config-nav" class="text-light font-mono">--</div>
                </div>
                <div class="me-3 text-end d-none d-lg-block">
                    <div class="small text-muted">Device ID</div>
                    <div id="id-config-nav" class="text-muted small">--</div>
                </div>
                <div class="me-3 text-end d-none d-lg-block">
                    <div class="small text-muted">WAN IP</div>
                    <div id="wan-ip-config-nav" class="text-jupiter font-mono">--</div>
                </div>

                <div class="me-3 text-end d-none d-lg-block">
                    <div class="small text-muted">LAN IP</div>
                    <div id="lan-ip-config-nav" class="text-jupiter font-mono">--</div>
                </div>

                <span class="badge bg-dark border border-secondary text-secondary me-3 font-mono"
                    id="version-config-nav">--</span>
            </div>
        </div>
    </nav>

    <div class="container-fluid">
        <div class="row">
            <main class="col-12 px-md-4 main-content">
                <div
                    class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-4 pb-3 mb-4 border-bottom border-secondary border-opacity-25">
                    <h1 class="h2">Dashboard <span class="text-muted fs-5 fw-light ms-2">| Visão Geral</span></h1>
                    <div class="btn-toolbar mb-2 mb-md-0">
                        <div class="btn-group me-2">
                            <button type="button" class="btn btn-sm btn-outline-secondary font-mono"
                                onclick="fetchLogs()">Exportar Logs</button>
                        </div>
                    </div>
                </div>

                <div class="row g-4 mb-5">
                    <div class="col-md-6 col-lg-3">
                        <div class="dash-card">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <h6 class="text-muted text-uppercase small mb-1">System Uptime</h6>
                                    <h2 class="card-value mt-1 mb-0" id="uptime">--</h2>
                                </div>
                                <div class="p-2 bg-jupiter-subtle rounded-2">
                                    <i class="bi bi-activity text-secondary fs-4"></i>
                                </div>
                            </div>
                            <div class="mt-3">
                                <small class="text-success font-mono"><i class="bi bi-check-circle-fill me-1"></i>Running</small>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6 col-lg-3">
                        <div class="dash-card">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h6 class="text-muted text-uppercase small mb-0">Network Traffic</h6>
                                <i class="bi bi-arrow-down-up text-jupiter"></i>
                            </div>

                            <div class="d-flex justify-content-between mb-1 font-mono small">
                                <span class="text-muted">RX (Down)</span>
                                <span class="text-light" id="rx-traffic">--</span>
                            </div>
                            <div class="progress mb-3" style="height: 4px;">
                                <div class="progress-bar bg-jupiter" style="width: 0%" id="rx-traffic-progress">
                                </div>
                            </div>

                            <div class="d-flex justify-content-between mb-1 font-mono small">
                                <span class="text-muted">TX (Up)</span>
                                <span class="text-light" id="tx-traffic">--</span>
                            </div>
                            <div class="progress" style="height: 4px;">
                                <div class="progress-bar bg-info" style="width: 0%" id="tx-traffic-progress"></div>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6 col-lg-3">
                        <div class="dash-card">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h6 class="text-muted text-uppercase small mb-0">CPU Temperature</h6>
                                <i class="bi bi-thermometer-half text-jupiter"></i>
                            </div>

                            <div class="d-flex justify-content-between align-items-end">
                                <div>
                                    <h2 class="card-value mt-1 mb-0" id="cpu-temp">--</h2>
                                </div>
                                <div class="text-end">
                                    <small class="text-muted d-block">Leitura atual</small>
                                    <small class="text-warning font-mono" id="cpu-temp-status">--</small>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6 col-lg-3">
                        <div class="dash-card">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h6 class="text-muted text-uppercase small mb-0">Modem Signal (RSSI)</h6>
                                <i class="bi bi-reception-4 text-jupiter"></i>
                            </div>

                            <div class="d-flex justify-content-between align-items-end">
                                <div>
                                    <h2 class="card-value mt-1 mb-0" id="modem-rssi">--</h2>
                                </div>
                                <div class="text-end">
                                    <small class="text-muted d-block">Intensidade</small>
                                    <small class="text-info font-mono" id="modem-rssi-status">--</small>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6 col-lg-3">
                        <div class="dash-card">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h6 class="text-muted text-uppercase small mb-0">Controle de Relés</h6>
                                <i class="bi bi-lightning-charge-fill text-jupiter"></i>
                            </div>

                            <div class="relay-controls">
                                <div class="relay-item mb-2">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <small class="text-muted">Relé 1</small>
                                        <div class="form-check form-switch m-0">
                                            <input class="form-check-input relay-toggle" type="checkbox" id="relay1-toggle" data-relay="1">
                                        </div>
                                    </div>
                                </div>
                                <div class="relay-item">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <small class="text-muted">Relé 2</small>
                                        <div class="form-check form-switch m-0">
                                            <input class="form-check-input relay-toggle" type="checkbox" id="relay2-toggle" data-relay="2">
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6 col-lg-3">
                        <div class="dash-card">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h6 class="text-muted text-uppercase small mb-0">Entrada de Tensão</h6>
                                <i class="bi bi-plug-fill text-jupiter"></i>
                            </div>

                            <div class="d-flex justify-content-between align-items-end">
                                <div>
                                    <h2 class="card-value mt-1 mb-0" id="vin-status">--</h2>
                                </div>
                                <div class="text-end">
                                    <small class="text-muted d-block">VIN GPIO</small>
                                    <small class="text-muted font-mono" id="vin-raw">--</small>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6 col-lg-3">
                        <div class="dash-card">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h6 class="text-muted text-uppercase small mb-0">Entradas Analógicas</h6>
                                <i class="bi bi-speedometer text-jupiter"></i>
                            </div>

                            <div class="ads1015-channels">
                                <div class="ads-channel mb-3">
                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                        <small class="text-muted">AIN0</small>
                                        <small class="text-success font-mono" id="ads-ch0-status">--</small>
                                    </div>
                                    <div class="d-flex justify-content-between">
                                        <small class="text-light font-mono" id="ads-ch0-voltage">Entrada: 0.000 V</small>
                                        <small class="text-muted font-mono small" id="ads-ch0-raw">ADS: --</small>
                                    </div>
                                    <div class="adc-cal-row mt-2">
                                        <input class="form-control form-control-sm bg-dark border-secondary text-light font-mono adc-scale-input"
                                            id="ads-ch0-gain" data-channel="0" inputmode="decimal" placeholder="ganho">
                                        <input class="form-control form-control-sm bg-dark border-secondary text-light font-mono adc-scale-input"
                                            id="ads-ch0-offset" data-channel="0" inputmode="decimal" placeholder="offset">
                                        <button class="btn btn-sm btn-outline-secondary" type="button"
                                            onclick="setAdsCalibration(0)" title="Aplicar calibração AIN0">
                                            <i class="bi bi-check2"></i>
                                        </button>
                                    </div>
                                </div>

                                <div class="ads-channel mb-3">
                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                        <small class="text-muted">AIN1</small>
                                        <small class="text-success font-mono" id="ads-ch1-status">--</small>
                                    </div>
                                    <div class="d-flex justify-content-between">
                                        <small class="text-light font-mono" id="ads-ch1-voltage">Entrada: 0.000 V</small>
                                        <small class="text-muted font-mono small" id="ads-ch1-raw">ADS: --</small>
                                    </div>
                                    <div class="adc-cal-row mt-2">
                                        <input class="form-control form-control-sm bg-dark border-secondary text-light font-mono adc-scale-input"
                                            id="ads-ch1-gain" data-channel="1" inputmode="decimal" placeholder="ganho">
                                        <input class="form-control form-control-sm bg-dark border-secondary text-light font-mono adc-scale-input"
                                            id="ads-ch1-offset" data-channel="1" inputmode="decimal" placeholder="offset">
                                        <button class="btn btn-sm btn-outline-secondary" type="button"
                                            onclick="setAdsCalibration(1)" title="Aplicar calibração AIN1">
                                            <i class="bi bi-check2"></i>
                                        </button>
                                    </div>
                                </div>

                                <div class="ads-channel mb-3">
                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                        <small class="text-muted">AIN2</small>
                                        <small class="text-success font-mono" id="ads-ch2-status">--</small>
                                    </div>
                                    <div class="d-flex justify-content-between">
                                        <small class="text-light font-mono" id="ads-ch2-voltage">Entrada: 0.000 V</small>
                                        <small class="text-muted font-mono small" id="ads-ch2-raw">ADS: --</small>
                                    </div>
                                    <div class="adc-cal-row mt-2">
                                        <input class="form-control form-control-sm bg-dark border-secondary text-light font-mono adc-scale-input"
                                            id="ads-ch2-gain" data-channel="2" inputmode="decimal" placeholder="ganho">
                                        <input class="form-control form-control-sm bg-dark border-secondary text-light font-mono adc-scale-input"
                                            id="ads-ch2-offset" data-channel="2" inputmode="decimal" placeholder="offset">
                                        <button class="btn btn-sm btn-outline-secondary" type="button"
                                            onclick="setAdsCalibration(2)" title="Aplicar calibração AIN2">
                                            <i class="bi bi-check2"></i>
                                        </button>
                                    </div>
                                </div>

                                <div class="ads-channel">
                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                        <small class="text-muted">AIN3</small>
                                        <small class="text-success font-mono" id="ads-ch3-status">--</small>
                                    </div>
                                    <div class="d-flex justify-content-between">
                                        <small class="text-light font-mono" id="ads-ch3-voltage">Entrada: 0.000 V</small>
                                        <small class="text-muted font-mono small" id="ads-ch3-raw">ADS: --</small>
                                    </div>
                                    <div class="adc-cal-row mt-2">
                                        <input class="form-control form-control-sm bg-dark border-secondary text-light font-mono adc-scale-input"
                                            id="ads-ch3-gain" data-channel="3" inputmode="decimal" placeholder="ganho">
                                        <input class="form-control form-control-sm bg-dark border-secondary text-light font-mono adc-scale-input"
                                            id="ads-ch3-offset" data-channel="3" inputmode="decimal" placeholder="offset">
                                        <button class="btn btn-sm btn-outline-secondary" type="button"
                                            onclick="setAdsCalibration(3)" title="Aplicar calibração AIN3">
                                            <i class="bi bi-check2"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h4 class="h5 text-light mb-0 d-flex align-items-center">
                        <i class="bi bi-speedometer2 me-2 text-secondary"></i> Telemetria em Tempo Real
                    </h4>
                </div>

                <div id="telemetry-container" class="row g-4 mb-5">
                    <div class="col-12 text-center text-muted py-5">
                        <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                        Aguardando dados dos sensores...
                    </div>
                </div>

                <section class="mb-5">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h4 class="h5 text-light mb-0 d-flex align-items-center">
                            <i class="bi bi-clock-history me-2 text-secondary"></i> Gerenciador de Tarefas
                        </h4>
                        <span class="badge bg-dark border border-secondary text-secondary font-mono" id="schedule-save-status">--</span>
                    </div>

                    <div class="scheduler-panel">
                        <div class="scheduler-toolbar">
                            <div>
                                <div class="d-flex align-items-center gap-2 mb-1">
                                    <span class="scheduler-title">Agendamento dos Relés</span>
                                    <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 font-mono"
                                        id="scheduler-status-badge">OFF</span>
                                </div>
                                <div class="text-muted small font-mono" id="scheduler-summary">0 regras configuradas</div>
                            </div>

                            <div class="scheduler-actions">
                                <div class="form-check form-switch scheduler-enable">
                                    <input class="form-check-input" type="checkbox" id="scheduler-enabled">
                                    <label class="form-check-label small text-muted" for="scheduler-enabled">Ativo</label>
                                </div>
                                <button type="button" class="btn btn-sm btn-outline-secondary font-mono" id="schedule-refresh-btn">
                                    <i class="bi bi-arrow-clockwise me-1"></i>Atualizar
                                </button>
                                <button type="button" class="btn btn-sm btn-jupiter font-mono" id="schedule-add-btn">
                                    <i class="bi bi-plus-lg me-1"></i>Nova Regra
                                </button>
                            </div>
                        </div>

                        <div id="schedule-rules-container" class="scheduler-table-wrap">
                            <div class="text-center text-muted py-4">
                                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                Carregando regras...
                            </div>
                        </div>
                    </div>
                </section>

                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h4 class="h5 text-light mb-0 d-flex align-items-center">
                        <i class="bi bi-terminal me-2 text-secondary"></i> Logs Recentes
                    </h4>
                    <span class="badge bg-dark border border-secondary text-secondary font-mono" id="logs-summary">--</span>
                </div>
                <div class="table-responsive">
                    <table class="table table-custom table-hover">
                        <thead>
                            <tr>
                                <th scope="col" style="width: 15%">Timestamp</th>
                                <th scope="col" style="width: 10%">Level</th>
                                <th scope="col" style="width: 15%">Module</th>
                                <th scope="col">Message</th>
                            </tr>
                        </thead>
                        <tbody id="logs-body">
                            <tr>
                                <td colspan="4" class="text-center text-muted py-3">
                                    <span class="spinner-border spinner-border-sm me-2" role="status"
                                        aria-hidden="true"></span>
                                    Conectando ao host de telemetria...
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </main>
        </div>
    </div>

    <script src="public/javascript.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>
